{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "insertFinalNewline": true,
  "endOfLine": "lf",
  "sortImports": {
    "groups": ["builtin", "external", ["parent", "sibling", "index"]],
    "newlinesBetween": true,
    "order": "asc"
  }
}
