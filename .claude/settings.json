{
  "permissions": {
    "allow": [
      "Bash(pnpm run check *)",
      "Bash(pnpm test *)",
      "Bash(pnpm check *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm audit *)",
      "Bash(pnpm format:check)",
      "Bash(pnpm tsc *)",
      "WebFetch(*)",
      "WebSearch(*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/completion-gate.sh",
            "statusMessage": "pnpm check を実行中..."
          }
        ]
      }
    ]
  }
}
