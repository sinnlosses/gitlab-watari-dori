{
  "name": "gitlab-watari-dori",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "dev": "tsx src/main.ts",
    "lint": "oxlint src && pnpm lint:validate-config",
    "lint:validate-config": "tsx scripts/lint/validate-config.ts",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit && oxlint src && oxfmt . --check && vitest run && pnpm lint:validate-config"
  },
  "dependencies": {
    "@gitbeaker/rest": "^41.0.0",
    "js-yaml": "^4.1.0",
    "p-limit": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.5.1"
}
