# GitLab インスタンスの URL（必須）
GITLAB_URL=https://gitlab.example.com

# MR 作成権限を持つ Personal Access Token（必須）
ACCESS_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# MR 作成をスキップするプロジェクト ID（カンマ区切り、任意）
# SKIP_PROJECT_IDS=123,456

# 設定ファイルまたはディレクトリのパス（任意、デフォルト: config/）
# CONFIG_PATH=config/

# 並列実行数（任意、デフォルト: 5）
# CONCURRENCY_LIMIT=5

# true のとき MR を作成せずログのみ出力する（任意、デフォルト: false）
# DRY_RUN=false
